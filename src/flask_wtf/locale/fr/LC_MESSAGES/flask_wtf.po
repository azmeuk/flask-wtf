#: src/flask_wtf/csrf.py:112
msgid "The CSRF token is missing."
msgstr "Le jeton CSRF est manquant."

#: src/flask_wtf/csrf.py:115
msgid "The CSRF session token is missing."
msgstr "Le jeton CSRF de session est manquant."

#: src/flask_wtf/csrf.py:122
msgid "The CSRF token has expired."
msgstr "Le jeton CSRF a expiré."

#: src/flask_wtf/csrf.py:124
msgid "The CSRF token is invalid."
msgstr "Le jeton CSRF est invalide."

#: src/flask_wtf/csrf.py:127
msgid "The CSRF tokens do not match."
msgstr "Les jetons CSRF ne correspondent pas."

#: src/flask_wtf/csrf.py:303
msgid "The referrer header is missing."
msgstr "L'en-tête Referer est manquant."

#: src/flask_wtf/csrf.py:309
msgid "The referrer does not match the host."
msgstr "Le Referer ne correspond pas à l'hôte."

#: src/flask_wtf/file.py:57
msgid "This field is required."
msgstr "Ce champ est obligatoire."

#: src/flask_wtf/file.py:96
#, python-brace-format
msgid "File does not have an approved extension: {extensions}"
msgstr "Le fichier n'a pas une extension autorisée : {extensions}"

#: src/flask_wtf/file.py:103
msgid "File does not have an approved extension."
msgstr "Le fichier n'a pas une extension autorisée."

#: src/flask_wtf/file.py:150
#, python-brace-format
msgid "File must be between {min} and {max} bytes."
msgstr "Le fichier doit faire entre {min} et {max} octets."

#: src/flask_wtf/recaptcha/validators.py:19
msgid "The secret parameter is missing."
msgstr "Le paramètre secret est manquant."

#: src/flask_wtf/recaptcha/validators.py:20
msgid "The secret parameter is invalid or malformed."
msgstr "Le paramètre secret est invalide ou malformé."

#: src/flask_wtf/recaptcha/validators.py:21
msgid "The response parameter is missing."
msgstr "Le paramètre de réponse est manquant."

#: src/flask_wtf/recaptcha/validators.py:22
msgid "The response parameter is invalid or malformed."
msgstr "Le paramètre de réponse est invalide ou malformé."
